# LLM provider (Groq using OpenAI-compatible API)
OPENAI_API_KEY=gsk_your_groq_api_key_here
OPENAI_MODEL=llama-3.1-8b-instant
OPENAI_BASE_URL=https://api.groq.com/openai/v1
GROQ_WHISPER_MODEL=whisper-large-v3

# Realtime alert tuning
COMPLAINT_SPIKE_THRESHOLD=5
CRITICAL_INCIDENT_THRESHOLD=3
ALERT_WINDOW_MINUTES=30

# Frontend → API (optional). If unset, the UI uses same-origin `/api` (Vite proxy in dev;
# configure your reverse proxy the same way in prod). Prefer unset for `npm run dev` so
# KPIs work when you open the app from another device on the LAN. Set a full URL only when
# the API is on a different host than the static UI.
# VITE_API_BASE_URL=http://127.0.0.1:8000
